---
interface HubCard {
  title: string;
  description: string;
  href: string;
  label?: string;
}

interface Props {
  eyebrow: string;
  headline: string;
  summary: string;
  primaryCtaHref: string;
  primaryCtaLabel: string;
  secondaryCtaHref: string;
  secondaryCtaLabel: string;
  cards: HubCard[];
}

const {
  eyebrow,
  headline,
  summary,
  primaryCtaHref,
  primaryCtaLabel,
  secondaryCtaHref,
  secondaryCtaLabel,
  cards,
} = Astro.props;
---

<section class="docs-hub-hero" data-pagefind-body>
  <p class="docs-hub-eyebrow">{eyebrow}</p>
  <h1 class="docs-hub-title">{headline}</h1>
  <p class="docs-hub-summary">{summary}</p>

  <div class="docs-hub-actions">
    <a class="docs-hub-btn docs-hub-btn--primary" href={primaryCtaHref}>{primaryCtaLabel}</a>
    <a class="docs-hub-btn docs-hub-btn--secondary" href={secondaryCtaHref}>{secondaryCtaLabel}</a>
  </div>
</section>

<section class="docs-hub-grid" data-pagefind-body>
  {cards.map((card) => (
    <a href={card.href} class="docs-hub-card">
      {card.label && <span class="docs-hub-card-label">{card.label}</span>}
      <h2 class="docs-hub-card-title">{card.title}</h2>
      <p class="docs-hub-card-description">{card.description}</p>
    </a>
  ))}
</section>

<style>
  .docs-hub-hero {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: clamp(1.5rem, 2.8vw, 2.8rem);
    background:
      radial-gradient(circle at 10% 10%, color-mix(in srgb, var(--color-accent-blue) 16%, transparent), transparent 48%),
      radial-gradient(circle at 90% 20%, color-mix(in srgb, var(--color-accent-cyan) 14%, transparent), transparent 40%),
      var(--color-bg-secondary);
    margin-bottom: var(--space-8);
  }

  .docs-hub-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin: 0 0 var(--space-4);
    padding: 0.4rem 0.75rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg-tertiary) 84%, transparent);
    color: var(--color-text-secondary);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    font-weight: var(--font-semibold);
  }

  .docs-hub-title {
    margin: 0 0 var(--space-4);
    font-size: clamp(2rem, 5vw, 3.15rem);
    line-height: 1.1;
  }

  .docs-hub-summary {
    margin: 0;
    max-width: 60ch;
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
  }

  .docs-hub-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }

  .docs-hub-btn {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.72rem 1.1rem;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    text-decoration: none;
    transition: transform var(--duration-slow) var(--ease-out), box-shadow var(--duration-slow) var(--ease-out), background-color var(--duration-slow) var(--ease-out), border-color var(--duration-slow) var(--ease-out);
  }

  .docs-hub-btn:hover {
    transform: translateY(-2px);
    text-decoration: none;
  }

  .docs-hub-btn--primary {
    background: var(--color-accent-blue);
    color: #fff;
    border: 1px solid color-mix(in srgb, var(--color-accent-blue) 70%, #000);
  }

  .docs-hub-btn--primary:hover {
    background: var(--color-accent-cyan);
    color: var(--color-text-inverse);
    box-shadow: var(--shadow-blue);
  }

  .docs-hub-btn--secondary {
    background: var(--color-bg-tertiary);
    color: var(--color-text-primary);
    border: 1px solid var(--color-border);
  }

  .docs-hub-btn--secondary:hover {
    border-color: var(--color-border-hover);
    background: var(--color-bg-secondary);
  }

  .docs-hub-grid {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .docs-hub-card {
    display: block;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    background: var(--color-bg-secondary);
    text-decoration: none;
    transition: transform var(--duration-slow) var(--ease-out), border-color var(--duration-slow) var(--ease-out), box-shadow var(--duration-slow) var(--ease-out);
  }

  .docs-hub-card:hover {
    transform: translateY(-3px);
    border-color: var(--color-accent-blue);
    box-shadow: var(--shadow-md);
    text-decoration: none;
  }

  .docs-hub-card-label {
    display: inline-block;
    margin-bottom: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    font-weight: var(--font-semibold);
  }

  .docs-hub-card-title {
    margin: 0 0 var(--space-2);
    padding: 0;
    border: 0;
    font-size: var(--text-xl);
  }

  .docs-hub-card-description {
    margin: 0;
    color: var(--color-text-secondary);
  }

  @media (min-width: 768px) {
    .docs-hub-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1180px) {
    .docs-hub-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
